graph TD
    classDef tensor fill:#f9f,stroke:#333,stroke-width:2px;
    classDef layer fill:#bbf,stroke:#333,stroke-width:2px;
    classDef custom fill:#bfb,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5;
    classDef loss fill:#fbb,stroke:#333,stroke-width:2px;

    Input["Input Tokens\n(Batch, SeqLen)"]:::tensor --> WTE["Word Token Embeddings\n(50257 -> 768)"]:::layer

    subgraph TransformerBlock["Transformer Block (x12)"]
        direction TB
        LN1["LayerNorm 1"]:::layer
        
        subgraph Attention["CausalSelfAttention"]
            direction TB
            FlattenQ["2D Tensor Flattening"]:::layer
            Q["Q Proj\n(768 -> 768)"]:::layer
            K["K Proj\n(768 -> 256)"]:::layer
            V["V Proj\n(768 -> 256)"]:::layer
            
            FlattenQ --> Q
            FlattenQ --> K
            FlattenQ --> V
            
            RoPE["Fused RoPE CustomOp"]:::custom
            
            Q --> RoPE
            K --> RoPE
            
            KCache["Grouped-Query\nKV Cache"]:::layer
            RoPE --> KCache
            V --> KCache
            
            Flash["Flash Attention 2\n(candle-flash-attn)"]:::custom
            
            RoPE --> Flash
            KCache --> Flash
            
            OutProj["Out Proj\n(768 -> 768)"]:::layer
            Flash --> OutProj
        end

        LN1 --> FlattenQ
        
        Add1((+)):::tensor
        
        LN2["LayerNorm 2"]:::layer
        
        subgraph FFN["FeedForward Network"]
            direction TB
            FlattenFFN["2D Tensor Flattening"]:::layer
            FC1["FC1 (768 -> 3072)"]:::layer
            GELU["GELU Activation"]:::layer
            FC2["FC2 (3072 -> 768)"]:::layer
            FlattenFFN --> FC1 --> GELU --> FC2
        end

        Add2((+)):::tensor
        
        Attention --> Add1
        Add1 --> LN2
        LN2 --> FlattenFFN
        FFN --> Add2
    end

    WTE --> LN1
    Add1 -.-> Add2

    LNFinal["Final LayerNorm"]:::layer
    Add2 --> LNFinal

    subgraph LMHead["Language Modeling Head"]
        direction TB
        LMLinear["LM Head Linear\n(768 -> 50257)"]:::layer
        Loss["FusedCrossEntropy PTX Kernel\n(CustomOp1: Fwd + Manual Autograd Bwd)"]:::custom
        
        LMLinear -->|Native BF16| Loss
    end

    LNFinal --> LMLinear
    Loss --> Output["Loss (Float32)"]:::loss
